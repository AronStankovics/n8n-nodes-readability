{
  "name": "n8n-nodes-reader-view",
  "version": "0.1.4",
  "description": "n8n community node that extracts the readable article (title, byline, main content) from a URL or HTML using Mozilla Readability — the same engine behind Firefox Reader View.",
  "license": "MIT",
  "homepage": "https://github.com/AronStankovics/n8n-nodes-readability",
  "keywords": [
    "n8n-community-node-package",
    "readability",
    "mozilla",
    "article",
    "reader-view",
    "scraping",
    "parser"
  ],
  "author": { "name": "Áron Stankovics", "email": "stankovics.aron@gmail.com" },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AronStankovics/n8n-nodes-readability.git"
  },
  "bugs": {
    "url": "https://github.com/AronStankovics/n8n-nodes-readability/issues"
  },
  "engines": { "node": ">=20.15" },
  "scripts": {
    "build": "n8n-node build",
    "build:watch": "tsc --watch",
    "dev": "n8n-node dev",
    "lint": "n8n-node lint",
    "lint:fix": "n8n-node lint --fix",
    "release": "n8n-node release",
    "prepublishOnly": "n8n-node prerelease",
    "test": "mocha",
    "integration-test": "mocha --spec 'test/*.test.ts' --spec 'test/integration/*.test.ts'",
    "coverage": "nyc --reporter=text --reporter=lcov npm test",
    "prepare": "husky"
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "n8n": {
    "n8nNodesApiVersion": 1,
    "strict": false,
    "nodes": ["dist/nodes/Readability/Readability.node.js"]
  },
  "lint-staged": {
    "*.ts": "eslint --fix"
  },
  "dependencies": {
    "@mozilla/readability": "^0.5.0",
    "jsdom": "^24.1.3",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@istanbuljs/nyc-config-typescript": "^1.0.2",
    "@n8n/node-cli": "*",
    "@types/chai": "^4.3.11",
    "@types/chai-as-promised": "^7.1.8",
    "@types/jsdom": "^21.1.7",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.11.0",
    "@types/proxyquire": "^1.3.31",
    "@types/qrcode": "^1.5.5",
    "chai": "^4.2.0",
    "chai-as-promised": "^7.1.1",
    "chai-spies": "^1.0.0",
    "eslint": "9.39.4",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.0",
    "mocha": "^10.1.0",
    "nyc": "^15.1.0",
    "prettier": "3.8.1",
    "proxyquire": "^2.1.0",
    "release-it": "19.2.4",
    "source-map-support": "^0.5.21",
    "ts-node": "^10.9.2",
    "typescript": "5.9.3"
  },
  "peerDependencies": { "n8n-workflow": "*" }
}
