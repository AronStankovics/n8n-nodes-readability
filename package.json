{
  "name": "n8n-nodes-reader-view",
  "version": "0.1.4",
  "description": "n8n community node that extracts the readable article (title, byline, main content) from a URL or HTML using Mozilla Readability — the same engine behind Firefox Reader View.",
  "license": "MIT",
  "homepage": "https://github.com/AronStankovics/n8n-nodes-readability",
  "keywords": [
    "n8n-community-node-package",
    "readability",
    "mozilla",
    "article",
    "reader-view",
    "scraping",
    "parser"
  ],
  "author": { "name": "Áron Stankovics", "email": "stankovics.aron@gmail.com" },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AronStankovics/n8n-nodes-readability.git"
  },
  "bugs": {
    "url": "https://github.com/AronStankovics/n8n-nodes-readability/issues"
  },
  "engines": { "node": ">=20.15" },
  "scripts": {
    "build": "n8n-node build",
    "build:watch": "tsc --watch",
    "dev": "n8n-node dev",
    "lint": "n8n-node lint",
    "lint:fix": "n8n-node lint --fix",
    "release": "n8n-node release",
    "prepublishOnly": "n8n-node prerelease",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "prepare": "husky"
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "n8n": {
    "n8nNodesApiVersion": 1,
    "strict": false,
    "nodes": ["dist/nodes/Readability/Readability.node.js"]
  },
  "lint-staged": {
    "*.ts": "eslint --fix"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "jsdom": "^24.1.3",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@n8n/node-cli": "*",
    "@types/jsdom": "^28.0.0",
    "@types/node": "^20.11.0",
    "@types/qrcode": "^1.5.5",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "9.39.4",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.0",
    "prettier": "3.8.1",
    "release-it": "20.0.0",
    "typescript": "5.9.3",
    "vitest": "^3.0.0"
  },
  "peerDependencies": { "n8n-workflow": "*" }
}
